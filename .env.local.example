# Generate with: openssl rand -base64 32
AUTH_SECRET=

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Local dev — set to your deployed URL in production
AUTH_URL=http://localhost:3000

# Neon connection string — from console.neon.tech → Dashboard → Connection string
# Use the pooled connection string (ends with -pooler.<region>.aws.neon.tech)
DATABASE_URL=

# The Google Workspace email that owns this booking page.
# Only this email can access /admin and bookings show up on this calendar.
OWNER_EMAIL=
